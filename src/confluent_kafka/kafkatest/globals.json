{
  "VerifiableProducer": {
    "class": "kafkatest.services.verifiable_client.VerifiableClientApp",
    "exec_cmd": "/opt/cfk-python/venv/bin/python -m confluent_kafka.kafkatest.verifiable_producer",
    "deploy": "/confluent-kafka-python/src/confluent_kafka/kafkatest/deploy.sh",
    "kill_signal": 15,
    "pids": "pgrep -f 'confluent_kafka.kafkatest.verifiable_producer'"
  },
  "VerifiableShareConsumer": {
    "class": "kafkatest.services.verifiable_client.VerifiableClientApp",
    "exec_cmd": "/opt/cfk-python/venv/bin/python -m confluent_kafka.kafkatest.verifiable_share_consumer",
    "deploy": "/confluent-kafka-python/src/confluent_kafka/kafkatest/deploy.sh",
    "kill_signal": 15,
    "pids": "pgrep -f 'confluent_kafka.kafkatest.verifiable_share_consumer'"
  }
}
